# =============================================================================
# GPU Server Environment — copy to .env and fill in values
# =============================================================================

# --- GPU ---
# Which GPUs to expose (e.g. "0", "0,1", "all")
NVIDIA_VISIBLE_DEVICES=all
# How many GPUs vLLM should use for tensor parallelism
GPU_COUNT=all

# --- vLLM ---
# HuggingFace model ID or local path inside the container
VLLM_MODEL=Qwen/Qwen2.5-14B-Instruct
# Name vLLM advertises for the model (used in litellm-config.yaml)
VLLM_SERVED_NAME=qwen2.5-14b
# Compute dtype: auto | float16 | bfloat16
VLLM_DTYPE=bfloat16
# Max context length (tokens) — tune to fit GPU VRAM
VLLM_MAX_MODEL_LEN=16384
# GPU memory fraction vLLM may use (0.0 – 1.0)
VLLM_GPU_MEM_UTIL=0.90
# Tensor-parallel shards (set to number of GPUs for multi-GPU)
VLLM_TENSOR_PARALLEL=1
# Host port for vLLM (internal traffic only; firewall off from internet)
VLLM_PORT=8000

# --- HuggingFace ---
# Token for gated models (Llama, Mistral, etc.)
HF_TOKEN=hf_xxxxxxxxxxxxxxxxxxxx
# Local directory where HF models are cached on the host
HF_CACHE_DIR=~/.cache/huggingface

# --- LiteLLM ---
# Master API key — clients (including Agenteach) use this to authenticate
LITELLM_MASTER_KEY=sk-your-secret-master-key
# Salt for hashing keys (optional but recommended)
LITELLM_SALT_KEY=
# Host port for LiteLLM proxy (expose this to Agenteach)
LITELLM_PORT=4000
# Optional: PostgreSQL URL for persistent key/usage storage
DATABASE_URL=
STORE_MODEL_IN_DB=false

# --- Monitoring (only used with --profile monitoring) ---
GRAFANA_PASSWORD=changeme
